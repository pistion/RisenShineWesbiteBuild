<%- include("partials/header") %>

<section class="hero-section">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-copy fade-up">
        <span class="hero-kicker">Curated Goods For Modern Living</span>
        <h1 class="hero-title">Built to Feel Premium Before Checkout Ever Begins</h1>
        <p class="hero-subtext">
          A polished storefront experience with boutique energy, strong product storytelling,
          and a catalog presentation that makes every item feel intentional.
        </p>
      </div>

      <div class="hero-actions fade-up fade-delay-1">
        <p class="hero-actions-label">Start with the hero actions</p>
        <a class="btn btn-brand" href="/products">
          <span class="hero-btn-copy">
            <strong>Shop Collection</strong>
            <small>Browse the full storefront</small>
          </span>
        </a>
        <a class="btn btn-soft" href="#featured-collection">
          <span class="hero-btn-copy">
            <strong>View Featured Picks</strong>
            <small>Jump to curated highlights</small>
          </span>
        </a>
      </div>
    </div>
  </div>
</section>

<section class="section-space">
  <div class="container">
    <div class="section-head fade-up">
      <p class="section-kicker">Storefront Direction</p>
      <h2 class="section-title">A homepage that sells atmosphere, not just inventory</h2>
    </div>
    <article class="story-card fade-up fade-delay-1">
      <h2 class="section-title story-title">Clean merchandising with a more editorial first impression.</h2>
      <p class="section-body">
        This layout is designed to make your catalog feel curated and elevated. Large imagery,
        softer luxury tones, and clearer product presentation give the storefront a stronger brand
        identity from the first screen.
      </p>
      <p class="section-body story-meta">
        Category-ready. Mobile-friendly. Easy to extend into collections, promotions, and checkout.
      </p>
    </article>
  </div>
</section>

<section class="values-section">
  <div class="container">
    <div class="section-head fade-up">
      <p class="section-kicker">Why It Works</p>
      <h2 class="section-title">More confidence in the UI means more confidence in the products</h2>
    </div>
    <div class="value-grid">
      <article class="value-card fade-up">
        <span class="value-icon">01</span>
        <h3>Stronger First Impression</h3>
        <p>Hero-driven storytelling gives the storefront a premium, memorable opening.</p>
      </article>
      <article class="value-card fade-up fade-delay-1">
        <span class="value-icon">02</span>
        <h3>Sharper Catalog Flow</h3>
        <p>Product sections feel curated instead of dumped into a generic grid.</p>
      </article>
      <article class="value-card fade-up fade-delay-2">
        <span class="value-icon">03</span>
        <h3>Better Expansion Path</h3>
        <p>The page structure leaves room for collections, testimonials, campaigns, and promos.</p>
      </article>
      <article class="value-card fade-up fade-delay-3">
        <span class="value-icon">04</span>
        <h3>More Premium Visual Tone</h3>
        <p>Typography, spacing, and layering create a more intentional brand presence.</p>
      </article>
    </div>
  </div>
</section>

<section id="featured-collection" class="section-space section-tight-top">
  <div class="container">
    <div class="section-heading-row fade-up">
      <div class="section-head section-head-inline">
        <p class="section-kicker">Featured Collection</p>
        <h2 class="section-title">Curated product highlights</h2>
      </div>
      <a class="btn btn-brand" href="/products">Shop All Products</a>
    </div>

    <% const homeFallbackGallery = [
      "https://images.unsplash.com/photo-1496747611176-843222e1e57c?auto=format&fit=crop&w=1200&q=80",
      "https://images.unsplash.com/photo-1529139574466-a303027c1d8b?auto=format&fit=crop&w=1200&q=80",
      "https://images.unsplash.com/photo-1509631179647-0177331693ae?auto=format&fit=crop&w=1200&q=80",
      "https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?auto=format&fit=crop&w=1200&q=80",
      "https://images.unsplash.com/photo-1483985988355-763728e1935b?auto=format&fit=crop&w=1200&q=80",
      "https://images.unsplash.com/photo-1495385794356-15371f348c31?auto=format&fit=crop&w=1200&q=80"
    ]; %>

    <% if (!products.length) { %>
      <div class="empty-state polished-card">
        <p>No featured products available yet.</p>
      </div>
    <% } else { %>
      <div class="showcase-grid">
        <% products.forEach((product, index) => { %>
          <% const image = product.images && product.images.length ? product.images[0] : homeFallbackGallery[index % homeFallbackGallery.length]; %>
          <article class="showcase-card fade-up <%= index > 1 ? 'fade-delay-1' : '' %>">
            <a href="/products/<%= product._id %>" class="showcase-image-link" aria-label="View <%= product.name %>">
              <img src="<%= image %>" alt="<%= product.name %>" class="showcase-image" loading="lazy" />
            </a>
            <div class="showcase-meta">
              <p class="showcase-category"><%= product.category %></p>
              <h3 class="showcase-name"><a href="/products/<%= product._id %>"><%= product.name %></a></h3>
              <p class="showcase-price"><%= formatCurrency(product.price) %></p>
            </div>
          </article>
        <% }); %>
      </div>
    <% } %>
  </div>
</section>

<section class="gallery-section">
  <div class="container">
    <div class="section-head fade-up">
      <p class="section-kicker">Visual Moodboard</p>
      <h2 class="section-title">A storefront style that feels curated and editorial</h2>
      <p class="section-body">
        The visual direction here is meant to elevate everyday product browsing into a more
        polished shopping experience.
      </p>
    </div>

    <div class="gallery-grid fade-up fade-delay-1">
      <a href="/products" class="gallery-item"><img src="https://images.unsplash.com/photo-1509631179647-0177331693ae?auto=format&fit=crop&w=900&q=80" alt="Editorial storefront mood" loading="lazy" /></a>
      <a href="/products" class="gallery-item"><img src="https://images.unsplash.com/photo-1529139574466-a303027c1d8b?auto=format&fit=crop&w=900&q=80" alt="Lifestyle presentation" loading="lazy" /></a>
      <a href="/products" class="gallery-item"><img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?auto=format&fit=crop&w=900&q=80" alt="Curated product styling" loading="lazy" /></a>
      <a href="/products" class="gallery-item"><img src="https://images.unsplash.com/photo-1496747611176-843222e1e57c?auto=format&fit=crop&w=900&q=80" alt="Luxury-inspired visuals" loading="lazy" /></a>
    </div>
  </div>
</section>

<section class="trust-section">
  <div class="container">
    <div class="section-head fade-up">
      <p class="section-kicker">Experience Layer</p>
      <h2 class="section-title">Designed to make the store feel established from day one</h2>
    </div>
    <div class="trust-grid">
      <article class="trust-card fade-up">
        <p class="trust-quote">"The homepage feels like a real brand, not just a starter template with products dropped into it."</p>
        <p class="trust-name">UI Direction</p>
      </article>
      <article class="trust-card fade-up fade-delay-1">
        <p class="trust-quote">"The products page gives every item more presence, which makes the catalog easier to trust and browse."</p>
        <p class="trust-name">Catalog Strategy</p>
      </article>
      <article class="trust-card fade-up fade-delay-2">
        <p class="trust-quote">"This visual system is ready for future collections, checkout, promos, and branded campaigns."</p>
        <p class="trust-name">Scalability</p>
      </article>
    </div>
  </div>
</section>

<section class="cta-section">
  <div class="container">
    <div class="cta-panel fade-up">
      <h2 class="cta-heading">Browse the full collection</h2>
      <p class="section-body">
        Explore the full catalog with the upgraded card layout, gallery modal, and stronger visual hierarchy.
      </p>
      <a href="/products" class="btn btn-brand">Open Products</a>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
