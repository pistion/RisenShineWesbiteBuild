<%- include("partials/header") %>

<section class="catalog-shell">
  <div class="container">
    <div class="catalog-topbar">
      <div>
        <p class="section-kicker">Catalog</p>
        <h1 class="catalog-title">Shop Collection</h1>
        <p class="catalog-subtitle">Refined product cards with softer surfaces, clearer information, and an easier add-to-cart flow.</p>
      </div>
    </div>

    <% if (!products.length) { %>
      <div class="empty-state polished-card">
        <p>No products found. Run <code>npm run seed</code> to insert sample data.</p>
      </div>
    <% } else { %>
      <% const fallbackGallery = [
        "https://images.unsplash.com/photo-1496747611176-843222e1e57c?auto=format&fit=crop&w=1200&q=80",
        "https://images.unsplash.com/photo-1485230895905-ec40ba36b9bc?auto=format&fit=crop&w=1200&q=80",
        "https://images.unsplash.com/photo-1529139574466-a303027c1d8b?auto=format&fit=crop&w=1200&q=80",
        "https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?auto=format&fit=crop&w=1200&q=80",
        "https://images.unsplash.com/photo-1543163521-1bf539c55dd2?auto=format&fit=crop&w=1200&q=80",
        "https://images.unsplash.com/photo-1584917865442-de89df76afd3?auto=format&fit=crop&w=1200&q=80"
      ]; %>

      <% const tagMap = {
        Footwear: ["EU38", "BLACK/WHITE"],
        Bags: ["UTILITY", "ESPRESSO"],
        Electronics: ["WIRELESS", "MIDNIGHT"],
        Home: ["HAND-FINISH", "SOFT SAND"],
        Apparel: ["RELAXED FIT", "NATURAL"],
        Office: ["STUDIO", "GRAPHITE"]
      }; %>

      <section class="catalog-grid">
        <% products.forEach((product, index) => { %>
          <% const mainImage = product.images && product.images.length ? product.images[0] : fallbackGallery[index % fallbackGallery.length]; %>
          <% const cardTags = tagMap[product.category] || ["CURATED", "SIGNATURE"]; %>
          <% const cardAnimationClass = index % 3 === 1 ? "fade-delay-1" : index % 3 === 2 ? "fade-delay-2" : ""; %>

          <article class="catalog-card fade-up <%= cardAnimationClass %>">
            <div class="catalog-card-top">
              <button
                class="catalog-favorite"
                type="button"
                aria-label="Save <%= product.name %>"
                aria-pressed="false"
                data-favorite-id="<%= product._id %>"
              >
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path
                    d="M12 20.2l-1.2-1.1C5.4 14.2 2 11.1 2 7.3 2 4.8 3.9 3 6.3 3c1.5 0 3 .7 3.9 1.9C11.1 3.7 12.6 3 14.1 3 16.5 3 18.4 4.8 18.4 7.3c0 3.8-3.4 6.9-8.8 11.8L12 20.2z"
                    fill="none"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.8"
                  />
                </svg>
              </button>

              <a class="catalog-visual-link" href="/products/<%= product._id %>" aria-label="View <%= product.name %>">
                <span class="catalog-image-shadow" aria-hidden="true"></span>
                <img class="catalog-product-image" src="<%= mainImage %>" alt="<%= product.name %>" loading="lazy" />
              </a>
            </div>

            <div class="catalog-card-bottom">
              <div class="catalog-copy-block">
                <h2 class="catalog-product-name">
                  <a href="/products/<%= product._id %>"><%= product.name %></a>
                </h2>

                <div class="catalog-tags">
                  <span class="catalog-tag"><%= cardTags[0] %></span>
                  <span class="catalog-tag"><%= cardTags[1] %></span>
                </div>

                <p class="catalog-product-description"><%= product.description %></p>
              </div>

              <div class="catalog-footer">
                <div class="catalog-price-block">
                  <span class="catalog-price-label">Price</span>
                  <p class="catalog-product-price"><%= formatCurrency(product.price) %></p>
                </div>

                <form action="/cart/add" method="POST" class="js-add-cart-form catalog-cart-form">
                  <input type="hidden" name="productId" value="<%= product._id %>" />
                  <input type="hidden" name="quantity" value="1" />
                  <button
                    type="submit"
                    class="catalog-cart-btn"
                    data-product-name="<%= product.name %>"
                    data-quantity="1"
                    <%= product.stock <= 0 ? "disabled" : "" %>
                  >
                    <%= product.stock <= 0 ? "Out of stock" : "Add to cart" %>
                  </button>
                </form>
              </div>
            </div>
          </article>
        <% }); %>
      </section>
    <% } %>
  </div>
</section>

<div class="cart-feedback" id="cartFeedback" role="status" aria-live="polite"></div>

<%- include("partials/footer") %>
