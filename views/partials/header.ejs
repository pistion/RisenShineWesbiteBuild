<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= navActive === "home" || !pageTitle || pageTitle === "Rise&Shine" ? "Rise&Shine" : `${pageTitle} | Rise&Shine` %></title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="<%= bodyClass || 'default-page' %>">
    <header class="topbar">
      <div class="container topbar-inner">
        <a class="brand" href="/" aria-label="Rise and Shine Home">
          <span class="brand-monogram">R&S</span>
          <span class="brand-lockup">
            <span class="brand-wordmark">Rise&amp;Shine</span>
            <span class="brand-tag">Quiet essentials for an intentional life</span>
          </span>
        </a>
        <button
          class="nav-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="primaryNavigation"
          data-nav-toggle
        >
          <span class="nav-toggle-lines" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
          <span class="nav-toggle-label">Menu</span>
        </button>
        <nav class="main-nav-shell" aria-label="Primary Navigation" data-nav-shell>
          <div class="main-nav" id="primaryNavigation" data-nav-panel>
            <a class="nav-link <%= navActive === 'home' ? 'is-active' : '' %>" href="/">Home</a>
            <a class="nav-link <%= navActive === 'products' ? 'is-active' : '' %>" href="/products">Products</a>
            <a class="nav-link <%= navActive === 'about' ? 'is-active' : '' %>" href="/about">About</a>
            <a class="nav-link <%= navActive === 'contact' ? 'is-active' : '' %>" href="/contact">Contact</a>
            <a class="nav-link nav-link-pill <%= navActive === 'cart' ? 'is-active' : '' %> cart-nav-link" href="/cart">Cart (<%= cartItemCount || 0 %>)</a>
          </div>
        </nav>
      </div>
      <% if (fallbackMode) { %>
        <div class="status-banner">
          Demo mode: serving bundled sample products because MongoDB is offline.
        </div>
      <% } %>
    </header>
    <main class="<%= mainClass || 'container default-main' %>">
