<%- include("partials/header") %>

<section class="page-shell">
  <div class="container">
    <div class="page-hero">
      <div class="page-copy">
        <p class="page-eyebrow">Contact</p>
        <h1>Get in touch with the store team</h1>
        <p>
          This starter keeps contact simple for now, but the layout is ready to grow into a full
          contact form, support workflow, or CRM-connected customer service page.
        </p>
      </div>
    </div>

    <div class="contact-grid">
      <article class="contact-card">
        <p class="page-eyebrow">Direct Contact</p>
        <h2>Reach us directly</h2>
        <div class="contact-method">
          <span class="method-label">Email</span>
          <a class="method-value" href="mailto:hello@example-store.com">hello@example-store.com</a>
        </div>
        <div class="contact-method">
          <span class="method-label">Phone</span>
          <a class="method-value" href="tel:+15550107890">+1 (555) 010-7890</a>
        </div>
        <div class="contact-method">
          <span class="method-label">Address</span>
          <span class="method-value">100 Commerce St, San Francisco, CA</span>
        </div>
      </article>

      <article class="contact-card">
        <p class="page-eyebrow">Availability</p>
        <h2>Support hours</h2>
        <div class="contact-note">
          <p>Monday to Friday</p>
          <strong>9:00 AM - 5:00 PM</strong>
        </div>
        <div class="contact-note">
          <p>Typical response time</p>
          <strong>Within 1 business day</strong>
        </div>
        <div class="contact-actions">
          <a class="btn btn-brand" href="/products">Browse Products</a>
          <a class="btn btn-ghost" href="/">Return Home</a>
        </div>
      </article>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
